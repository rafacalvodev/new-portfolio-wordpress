---
import { getCollection } from "astro:content";
import VisitSite from "../../assets/icons/misc/CarbonArrowUpRight.svg";

const projects = await getCollection("projects");
const featuredProjects = projects.filter(
  (project) => project.data.featured === true,
);
---

<section class="home-section | projects-section">
  <div class="container">
    <div class="home-section__header | flow">
      <h2>Algunos de los proyectos en los que he trabajado</h2>
      <p></p>
    </div>
    {
      featuredProjects.length > 0 ? (
        <ul class="grid">
          {featuredProjects.map((project) => {
            const linkTarget = project.data.link ?? "/portafolio";
            const isExternal =
              typeof project.data.link === "string" &&
              /^(https?:)?\/\//.test(project.data.link);

            return (
              <li>
                <article class="card flow">
                  {project.data.image && (
                    <img
                      src={`/projects/${project.data.image}`}
                      alt={`${project.data.title} screenshot`}
                    />
                  )}

                  <h3>{project.data.title}</h3>

                  {project.data.features?.length ? (
                    <ul class="features-list | flow">
                      {project.data.features.map((feature) => (
                        <li>{feature}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="muted">No hay características listadas aún.</p>
                  )}

                  <a
                    class="button"
                    href={linkTarget}
                    target={isExternal ? "_blank" : "_self"}
                    rel={isExternal ? "noopener noreferrer" : undefined}
                    target={isExternal ? "_blank" : "_self"}
                  >
                    Visitar sitio Web <VisitSite />
                  </a>
                </article>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="home-section__empty">
          No hay proyectos destacados en este momento.
        </p>
      )
    }
  </div>
</section>

<style lang="scss">
  .projects-section {
    .grid {
      --minimun: 40ch;
    }

    img {
      aspect-ratio: auto;
      max-width: 100%;
      height: auto;
    }

    .features-list {
      list-style-type: disc;
      padding-left: 1em;
    }
  }
</style>

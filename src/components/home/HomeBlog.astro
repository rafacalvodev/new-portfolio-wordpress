---
import { fetchPosts } from "../../lib/wordpress";

const { posts } = await fetchPosts(3);
---

<section class="home-section | blog-section">
  <div class="container">
    <div class="home-section__header | flow">
      <h2>Últimas entradas del blog</h2>
      <p>Lee mis pensamientos más recientes sobre desarrollo web y diseño.</p>
    </div>
    <ul class="grid">
      {
        posts.map((post) => {
          const featuredImage = post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
          return (
            <li>
              <article class="card flow">
                {featuredImage && (
                  <img
                    src={featuredImage}
                    alt={post.title.rendered}
                    class="blog-card__image"
                    loading="lazy"
                  />
                )}
                <h3 set:html={post.title.rendered} />
                <p set:html={post.excerpt.rendered} />
                <div class="blog-card__meta | flex">
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString()}
                  </time>
                </div>
                <a class="button" href={`/blog/${post.slug}`}>
                  Leer más
                </a>
              </article>
            </li>
          );
        })
      }
    </ul>
    <div class="home-section__footer">
      <a class="button" href="/blog">Ver todas las entradas</a>
    </div>
  </div>
</section>

<style lang="scss">
  .blog-section {
    .grid {
      --minimun: 30ch;
    }

    .blog-card__image {
      width: 100%;
      height: auto;
      border-radius: 0.25em;
      margin-bottom: var(--space-xs);
    }

    .blog-card__meta {
      gap: var(--space-xs);
      font-size: var(--step--1);
      color: var(--text-200);
      margin-bottom: var(--space-xs);
    }

    .home-section__footer {
      text-align: center;
      margin-top: var(--space-l);
    }
  }
</style>

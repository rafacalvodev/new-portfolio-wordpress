---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="home-section | blog-section">
  <div class="container">
    <div class="home-section__header | flow">
      <h2>Últimas entradas del blog</h2>
      <p>Lee mis pensamientos más recientes sobre desarrollo web y diseño.</p>
    </div>
    <ul class="grid">
      {
        recentPosts.map((post) => (
          <li>
            <article class="card flow">
              {post.data.featuredImage && (
                <img
                  src={post.data.featuredImage}
                  alt={post.data.title}
                  class="blog-card__image"
                  loading="lazy"
                />
              )}
              <h3>{post.data.title}</h3>
              <p>{post.data.cardDescription ?? post.data.description}</p>
              <div class="blog-card__meta | flex">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString()}
                </time>
                <span>{post.data.readingTime} min de lectura</span>
              </div>
              <a class="button" href={`/blog/${post.id}`}>
                Leer más
              </a>
            </article>
          </li>
        ))
      }
    </ul>
    <div class="home-section__footer">
      <a class="button" href="/blog">Ver todas las entradas</a>
    </div>
  </div>
</section>

<style lang="scss">
  .blog-section {
    .grid {
      --minimun: 30ch;
    }

    .blog-card__image {
      width: 100%;
      height: auto;
      border-radius: 0.25em;
      margin-bottom: var(--space-xs);
    }

    .blog-card__meta {
      gap: var(--space-xs);
      font-size: var(--step--1);
      color: var(--text-200);
      margin-bottom: var(--space-xs);
    }

    .home-section__footer {
      text-align: center;
      margin-top: var(--space-l);
    }
  }
</style>

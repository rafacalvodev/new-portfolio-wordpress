---
import { fetchPosts } from "../../lib/wordpress";
import { stripHtml, estimateReadingTime } from "../../utils/readingTime";
import VisitPost from "../../assets/icons/misc/CarbonArrowRight.svg";

const { posts } = await fetchPosts(3, 1);
---

<section class="home-section | blog-section">
  <div class="container">
    <div class="home-section__header | flow">
      <h2>Últimas entradas del blog</h2>
      <p>Lee mis pensamientos más recientes sobre desarrollo web y diseño.</p>
    </div>
    <ul class="grid">
      {
        posts.map((post) => {
          const featuredImage =
            post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
          const description = stripHtml(post.excerpt.rendered);
          const readingTime = estimateReadingTime(
            stripHtml(post.content.rendered),
          );
          return (
            <li>
              <article class="card flow">
                {featuredImage && (
                  <img
                    src={featuredImage}
                    alt={post.title.rendered}
                    class="blog-card__image"
                    loading="lazy"
                  />
                )}
                <h3 set:html={post.title.rendered} />
                <p class="blog-card__description">{description}</p>

                <a class="button" href={`/blog/${post.slug}`}>
                  Leer más <VisitPost />
                </a>
              </article>
            </li>
          );
        })
      }
    </ul>
    <div class="home-section__footer">
      <a class="button" href="/blog">Ver todas las entradas</a>
    </div>
  </div>
</section>

<style lang="scss">
  .blog-section {
    .grid {
      --minimun: 30ch;
    }

    // .blog-card__image {

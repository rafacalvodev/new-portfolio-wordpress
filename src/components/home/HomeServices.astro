---
import { fetchServices } from "../../lib/wordpress";

const services = await fetchServices();
---

<section id="servicios" class="home-section">
  <div class="container | flow">
    <div class="home-section__header | flow">
      {Astro.props.title && <h2>{Astro.props.title}</h2>}
      <p>
        Servicios web pensados para PYMES y emprendimientos en Venezuela e
        internacionalmente: simples, efectivos y a tu medida. Desde crear tu
        primera página hasta vender online o aparecer en Google, te ayudo a
        crecer sin complicaciones.
      </p>
    </div>
    <div class="services-grid">
      <ul class="grid">
        {
          services.map((service) => {
            const title = service.acf?.service_title || service.title.rendered;
            const description = service.acf?.service_description || service.excerpt?.rendered;
            const url = service.acf?.service_url || `/servicios/${service.slug}`;
            return (
              <li>
                <article class="card cluster flow">
                  <h3 set:html={title} />
                  <p set:html={description} />
                  <a href={url} class="button">Más información</a>
                </article>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .cluster {
    align-items: stretch;
  }

  .service-icon {
    svg {
      max-width: 100%;
      width: 5em;
      height: 5em;

      path,
      circle {
        fill: var(--alert-100);
      }
    }
  }
</style>

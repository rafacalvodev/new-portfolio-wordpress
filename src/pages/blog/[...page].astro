---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import Pagination from "../../components/Pagination.astro";
import { fetchPosts } from "../../lib/wordpress";
import { stripHtml, estimateReadingTime } from "../../utils/readingTime";

import VisitPost from "../../assets/icons/misc/CarbonArrowRight.svg";

const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam) : 1;
const perPage = 6;

const { posts, total: totalPosts } = await fetchPosts(perPage, currentPage);
const totalPagesCount = Math.ceil(totalPosts / perPage);
---

<DefaultLayout
  title={`Blog${currentPage > 1 ? ` – Página ${currentPage}` : ""}`}
  description="Lee mis últimas reflexiones sobre desarrollo web y diseño."
>
  <header class="blog-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Lee mis últimas reflexiones sobre desarrollo web y diseño.</p>
    </div>
  </header>
  <section class="blog-posts">
    <div class="container">
      <ul class="grid">
        {
          posts.map((post) => {
            const featuredImage =
              post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
            const description = stripHtml(post.excerpt.rendered);
            const readingTime = estimateReadingTime(
              stripHtml(post.content.rendered),
            );
            return (
              <li>
                <article class="card | flow">
                  {featuredImage && (
                    <img
                      src={featuredImage}
                      alt={post.title.rendered}
                      class="blog-card__image"
                      loading="lazy"
                    />
                  )}
                  <div class="blog-card__content | flex">
                    <h2 class="blog-card__title">
                      <a
                        href={`/blog/${post.slug}`}
                        set:html={post.title.rendered}
                      />
                    </h2>
                    <p
                      class="blog-card__description"
                      set:html={post.excerpt.rendered}
                    />
                  </div>
                  <div class="blog-card__link">
                    <a class="button" href={`/blog/${post.slug}`}>
                      Leer más <VisitPost />
                    </a>
                  </div>
                </article>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
  <div id="pagination">
    <div class="container flex">
      <Pagination
        basePath="/blog"
        previousPage={currentPage > 1 ? `/blog/${currentPage - 1}` : null}
        nextPage={currentPage < totalPagesCount
          ? `/blog/${currentPage + 1}`
          : null}
        currentPage={currentPage}
        totalPages={totalPagesCount}
      />
    </div>
  </div>
</DefaultLayout>

<style lang="scss">
  @use "../../assets/scss/abstracts/colors.scss" as *;

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    --minimun: 28ch;
  }

  .flex {
    justify-content: space-between;
    flex-direction: column;
    align-items: flex-start;
  }


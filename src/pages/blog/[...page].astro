---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import Pagination from "../../components/Pagination.astro";
import { getCollection } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog");
  const sortedPosts = posts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );

  return paginate(sortedPosts, { pageSize: 6 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
---

<DefaultLayout
  title={`Blog – Página ${page.currentPage}`}
  description="Read my latest thoughts on web development and design."
>
  <header class="blog-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Read my latest thoughts on web development and design.</p>
    </div>
  </header>
  <section class="blog-posts">
    <div class="container">
      <div class="grid">
        {
          page.data.map((post) => (
            <article class="flow | card">
              {post.data.featuredImage && (
                <img
                  src={post.data.featuredImage}
                  alt={post.data.title}
                  class="blog-card__image"
                  loading="lazy"
                />
              )}
              <div class="blog-card__content flex">
                <div class="blog-card__tags | flex">
                  {post.data.tags?.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="blog-card__description">
                  {post.data.cardDescription ?? post.data.description}
                </p>
                <div class="blog-card__meta">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString()}
                  </time>
                  <span> • {post.data.readingTime} min read</span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
  <div id="pagination">
    <div class="container flex">
      <Pagination
        basePath="/blog"
        previousPage={page.url.prev ? page.url.prev : null}
        nextPage={page.url.next ? page.url.next : null}
        currentPage={page.currentPage}
        totalPages={Math.ceil(page.total / page.size)}
      />
    </div>
  </div>
</DefaultLayout>

<style lang="scss">
  @use "../../assets/scss/abstracts/colors.scss" as *;

  .grid {
    --minimun: 24ch;
  }

  .flex {
    justify-content: space-between;
    flex-direction: column;
    align-items: flex-start;
  }

  .blog-card {
    &__image {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    &__title a {
      color: inherit;
      text-decoration: none;
    }

    &__title a:hover {
      text-decoration: underline;
      text-decoration-style: wavy;
      text-decoration-thickness: 1px;
    }

    &__meta {
      font-size: var(--step--1);
      margin-top: auto;
    }

    &__tags {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }

  .tag {
    background: var(--alert-100);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: var(--step--2);
    color: #000;
  }
</style>

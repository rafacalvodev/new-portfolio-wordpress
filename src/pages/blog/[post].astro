---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import { fetchPostBySlug } from "../../lib/wordpress";
import { stripHtml, estimateReadingTime } from "../../utils/readingTime";

const slug = Astro.params.post;
const post = await fetchPostBySlug(slug || "");

if (!post) {
  return Astro.redirect("/404");
}
const readingTime = estimateReadingTime(stripHtml(post.content.rendered));
---

<DefaultLayout
  title={post.title.rendered}
  image={post._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
    "/social-preview-image.png"}
>
  <article id="blog-post">
    <div class="post-hero">
      <div class="container | flow">
        {
          post._embedded?.["wp:featuredmedia"]?.[0]?.source_url && (
            <img
              src={post._embedded["wp:featuredmedia"][0].source_url}
              alt={`Imagen destacada: ${post.title.rendered}`}
              class="blog-card__image"
              loading="lazy"
            />
          )
        }
        <h1 set:html={post.title.rendered} />
        <div class="post-meta">
          <time datetime={post.date}>
            {
              new Date(post.date).toLocaleDateString("es-ES", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })
            }
          </time>
          🔹
          <span>{readingTime} min de lectura</span>
        </div>
      </div>
    </div>
    <div class="post-content">
      <div class="container">
        <div class="flow | prose" set:html={post.content.rendered} />
      </div>
    </div>
  </article>

  <script type="application/ld+json" is:inline>
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title.rendered,
      "description": post.excerpt?.rendered?.replace(/<[^>]*>/g, "").substring(0, 155),
      "image": post._embedded?.["wp:featuredmedia"]?.[0]?.source_url,
      "author": {
        "@type": "Person",
        "name": "Rafael Calvo",
      },
      "publisher": {
        "@type": "Organization",
        "name": "Rafael Calvo - Desarrollador Web Freelance",
        "logo": {
          "@type": "ImageObject",
          "url": `${Astro.site}favicon.svg`,
        },
      },
      "datePublished": post.date,
      "dateModified": post.modified || post.date,
    })}
  </script>
</DefaultLayout>

<style lang="scss">
  @use "../../assets/scss/abstracts/colors.scss" as *;

  #blog-post {
    font-family: "Piazzolla", Georgia, "Times New Roman", Times, serif;

    h1 {
      font-family: "Lexend", "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    h2,
    h3,
    h4 {
      font-family: "Piazzolla", Georgia, "Times New Roman", Times, serif;
    }
  }

  article {
    margin-block: 2rem;
  }

  .post-hero {
    margin-block: 2rem;
  }

  .description {
    font-size: var(--step-1);
    color: var(--text-color-secondary);
    font-style: italic;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: "Courier New", Courier, monospace;
  }

  .tag {
    background: var(--alert-100);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: var(--step--2);
    color: black;
  }

  .prose {
    max-width: var(--font-measure);
    line-height: 1.7;
  }

  .prose :global(h2) {
    margin-top: 2rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(code) {
    background: var(--background-color-secondary);
    padding: 0.125rem 0.25rem;
    border-radius: 3px;
    font-family: monospace;
  }

  .prose :global(pre) {
    background: var(--background-color-secondary);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
  }
</style>
